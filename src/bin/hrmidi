# - - - - - - - output functions
def print_version():
	print(f'hrmidi version: {version}')
	sys.exit(0)

def print_error(text: str):
	print(f'hrmidi: error: compiler failed with {text} !')
	sys.exit(1)

def print_warning(text: str) -> None:
	if stdout: return
	print(f'hrmidi: warning: {text}')

# - - - - - - - processing functions
def parse_hrmidi() -> list:
	def str_to_number(s: str) -> int | float | str:
		try:
			output = int(s)
		except:
			try:
				output = float(s)
			except:
				try :
					output = int(s.split("/")[0]) / int(s.split("/")[1])
				except:
					output = s
		return output

	def get_term(lines: dict, term_name: str, optional: bool = False) -> str | None:
		term_line: str | None = next((line for line in lines.values() if line.startswith(term_name)), None)
		if not term_line:
			if optional: return None
			print_error(f'{term_name} line not found')
		term: str = re.split(r'[;\s]+', term_line)[-1]
		if term == term_name or (not term): print_error(f'no {term_name} specified')
		return term

	lines: dict[int,str] = {number:valid for number,line in enumerate(file.split("\n"), start=1) if (valid := line.split("//")[0].strip().lower().replace(",", "."))}
	
	lang: str = get_term(lines, "lang")
	match lang:
		case "en":
			instruments = en_instruments
			clefs = en_clefs
		case "pt":
			instruments = pt_instruments
			clefs = pt_clefs
		case _:
			print_error(f'lang "{lang}" is invalid')
	del lang
	
	bpm = get_term(lines, "bpm")
	bpm = str_to_number(bpm)
	if isinstance(bpm,str): print_error(f'invalid bpm number: "{bpm}"')
	
	ver = get_term(lines, "ver", optional=True)
	if ver:
		if ver != version: print_warning(f'file version is "{ver}", this program version is "{version}"')
	else:
		print_warning('no version specified on file')
	
	source: list = [bpm]
	detected_lang: bool = False; detected_bpm: bool = False; detected_ver: bool = False; detected_dodeca = False
	step: dict = {"c": False, "n": False, "t": False, "m": False}
	instruments_used: set = set()
	temp: dict = {}
	for number, line in lines.items():
		if line.startswith("lang"):
			if detected_lang:
				print_error(f"duplicated lang at line {number}")
			else:
				detected_lang = True; continue
		if line.startswith("bpm"):
			if detected_bpm:
				print_error(f"duplicated bpm at line {number}")
			else:
				detected_bpm = True; continue
		if line.startswith("ver"):
			if detected_ver:
				print_error(f"duplicated ver at line {number}")
			else:
				detected_ver = True; continue
		if line.startswith("dodeca"):
			if detected_dodeca:
				print_error(f"duplicated dodeca at line {number}")
			else:
				detected_dodeca = True; continue
		
		if line.startswith("c_"):
			if step["c"]:
				if step["n"]:
					if step["t"]:
						if len(temp['keys']) != len(temp['times']): print_error(f"track above line {number} have different number of keys and times")
						temp["instrument"] = instruments[temp["instrument"]]
						source.append(temp)
						step: dict = {"c": False, "n": False, "t": False, "m": False}
					else:
						print_error(f"new track started at line {number} withowt finish the previous (missing time section)")
				else:
					print_error(f"new track started at line {number} withowt finish the previous (missing at least keys section)")
			step["c"] = True
			items = re.split(r'[;\s]+', line)
			if len(items) != 2: print_error(f"invalid arguments number at line {number} (must be two)")
			instrument: str = items[0].replace('c_', '')
			if instrument not in instruments.keys(): print_error(f"invalid instrument name at line {number}")
			clef = str_to_number(items[1])
			if not isinstance(clef, int):
				if clef not in clefs.keys(): print_error(f"invalid clef name at line {number}")
				clef = clefs[clef]
			if -5 > clef > 5: print_error(f"invalid clef at line {number} (limit is from -5 to 5)")
			temp = {'instrument': instrument, 'clef': clef, "modifier": 1, "keys": [], "shift": [], "times": []}
			instruments_used.add(instruments[instrument])
			if len(instruments_used) > 15: print_error("too many normal instruments used, the limit is 15")
			continue
		if line.startswith("n_"):
			if not step["c"]: print_error(f"line {number} does not have clef declaration above")
			if step["n"]: print_error(f"duplicate and/or invalid keys section at line {number}")
			items = re.split(r'[;\s]+', line)
			if len(items) < 2: print_error(f"invalid arguments number at line {number} (must be at least two)")
			instrument: str = items[0].replace('n_', '')
			if temp["instrument"] != instrument: print_error(f"instrument at line {number} is not the same declared on clef")
			for key in items[1:]:
				k: str = f"{key}"
				shift: int = (key.count('+') - key.count('-'))
				key = key.replace('-', '').replace('+', '')
				if detected_dodeca: key = str_to_number(key)
				if key not in keys.keys(): print_error(f"invalid key '{k}' at line {number}")
				if 1 > (key + ((track['clef'] + 5) * 12) + (shift * 12)) > 128: print_error(f"key '{k}' at line {number} is too high or too low") # Check make_midi() to more info on this math
				temp["keys"].append(keys[key])
				temp["shift"].append(shift)
			step["n"] = True
			continue
		if line.startswith("t_"):
			if not step["c"]: print_error(f"line {number} does not have clef declaration above")
			if step["t"]: print_error(f"duplicate and/or invalid time section at line {number}")
			items = re.split(r'[;\s]+', line)
			if len(items) < 2: print_error(f"invalid arguments number at line {number} (must be at least two)")
			instrument: str = items[0].replace('t_', '')
			if temp["instrument"] != instrument: print_error(f"instrument at line {number} is not the same declared on clef")
			for time in items[1:]:
				time = str_to_number(time)
				if isinstance(time, str): print_error(f"invalid time '{time}' at line {number}")
				temp["times"].append(time)
			step["t"] = True
			continue
		if line.startswith("m_"):
			if not step["c"]: print_error(f"line {number} does not have clef declaration above")
			if step["m"]: print_error(f"duplicate and/or invalid modifier at line {number}")
			items = re.split(r'[;\s]+', line)
			if len(items) != 2: print_error(f"invalid arguments number at line {number} (must be two)")
			instrument: str = items[0].replace('m_', '')
			if temp["instrument"] != instrument: print_error(f"instrument at line {number} is not the same declared on clef")
			modifier = str_to_number(items[1])
			if isinstance(modifier, str): print_error(f"modifier at line {number} must be a valid number or fraction")
			if modifier == 0: print_error(f"modifier at line {number} cannot be zero")
			temp["modifier"] = modifier
			step["m"] = True
			continue
		print_error(f"unknow instruction at line {number}")
	
	if not step["c"]: print_error(f"no tracks found")
	if not step["n"]: print_error(f"last track missing at least keys section")
	if not step["t"]: print_error(f"last track missing time section")
	if len(temp['keys']) != len(temp['times']): print_error(f"last track have different number of keys and times")
	temp["instrument"] = instruments[temp["instrument"]]
	source.append(temp)
	return source

def make_midi() -> bytes:
	def vlq(i:int) -> bytes:
		o:list = [i & 0x7F]
		i >>= 7
		while i:
			o.append((i & 0x7F)|0x80)
			i >>= 7
		return bytes(reversed(o))

	def mtrk(i:list[bytes]) -> bytes:
		o:bytes = b"".join(i)
		o += vlq(0)
		o += bytes([0xFF, 0x2F, 0x00]) # End of Track
		return b"MTrk" + len(o).to_bytes(4, 'big') + o

	result: bytearray = bytearray()

	result += b"MThd"							# Header begin
	result += (6).to_bytes(4, 'big')			# Header standard size
	result += (1).to_bytes(2, 'big')			# Midi format, there is 0, 1 and 2
	result += (len(source)).to_bytes(2, 'big')	# How many track chunks
	result += (960).to_bytes(2, 'big')			# Some timing stuff

	result += mtrk([
		vlq(0)																	# Deltatime
		,bytes([0xFF, 0x58, 0x04, 0x04, 0x02, 0x18, 0x08])						# Time Signature
		,vlq(0)																	# Deltatime
		,bytes([0xFF, 0x51, 0x03]) + (60000000 // source[0]).to_bytes(3, 'big')	# Set Tempo
	])

	for channel, track in enumerate(source[1:]):
		chunk: list[bytes] = [
			vlq(0)
			,bytes([0xC0 | channel])
			,bytes([track['instrument'] - 1])
		]

		delay: int = 0
		for k, s, t in zip(track['keys'], track['shift'], track['times']):
			t = int(t * 960 / track['modifier'])
			if k != 0:
				k -= 1 # In midi they start at 0, not 1
				k += ((track['clef'] + 5) * 12) # Sets the clef
				k += (s * 12) # Shift the clef
				chunk += [
					vlq(delay)					# When the note will start, after previous event
					,bytes([0x90 | channel])	# Note On Event
					,bytes([k])					# Note Value
					,bytes([63])				# "velocity" - in pratice the volume
					,vlq(t)						# When the note will end
					,bytes([0x80 | channel])	# Note Off Event
					,bytes([k])					# Note Value
					,bytes([0])					# "velocity" - some instruments may act diferent with non 0
				]
				delay = 0
			else:
				delay += t
		result += mtrk(chunk)

	return bytes(result)

def make_hr() -> str:
	global hrmidi_format
	result: str = f"LANG {language}\nBPM {source[0]}\n\n"
	if not hrmidi_format:
		hrmidi_format = ""

	if 'a' in hrmidi_format:
		keys_dict: dict = keys_alpha.copy()
	elif 'f' in hrmidi_format:
		keys_dict: dict = keys_phonetic.copy()
	else:
		keys_dict: dict = keys_numeric.copy()

	if '_' in hrmidi_format:
		keys_dict[0] = "_" 
	else:
		keys_dict[0] = "0"

	instruments_dict: dict = {}
	clefs_dict: dict = {}
	match language:
		case 'en':
			for i, n in en_instruments.items():
				instruments_dict[n] = i
			if 'm' in hrmidi_format:
				clefs_dict = {n:str(n) for n in range(-16, 17)}
			else:
				for i, n in en_clefs.items():
					clefs_dict[n] = i
		case 'pt':
			for i, n in pt_instruments.items():
				instruments_dict[n] = i
			if 'm' in hrmidi_format:
				clefs_dict = {n:str(n) for n in range(-16, 17)}
			else:
				for i, n in pt_clefs.items():
					clefs_dict[n] = i

	convert_modifier: bool = ('c' in hrmidi_format)

	for track in source[1:]:
		instrument: str = instruments_dict[track["instrument"]].upper()
		modifier = track['modifier']
		result += f"C_{instrument} {clefs_dict[track['clef']]}\nN_{instrument} "
		for key, shift in zip(track['keys'], track['shift']):
			if shift < 0:
				result += (-shift * "-")
			elif shift > 0:
				result += (shift * "+")
			result += keys_dict[key]
			result += " 	"
		result += f"\nT_{instrument} "
		for time in track['times']:
			if convert_modifier:
				time = (time / modifier)
			result += str(time)
			result += " 	"
		if not convert_modifier:
			result += f"\nM_{instrument} {modifier}"
		result += "\n\n"

	return result

# - - - - - - - main
if __name__ == "__main__":
	parser: ArgumentParser = ArgumentParser(
		prog="hrmidi"
		,description="Compiler for hrmidi language."
	)

	parser.add_argument('-v', '--version', action='store_true', help='Shows program version.')
	parser.add_argument('-l', metavar='language', default='midi', choices=languages, help='The output language (Default: midi).')
	parser.add_argument('-f', metavar='format', default=None, help='The formating for non midi output.')
	parser.add_argument('-o', metavar='output_file', default=None, help='The name of output file.')
	parser.add_argument('--stdout', action='store_true', help='Outputs to stdout instead file.')
	parser.add_argument('file', help='Name of the input file.')

	args = parser.parse_args()
	if args.version: print_version()
	try:
		with open(args.file, 'r') as f: file = f.read()
	except FileNotFoundError:
		print(f"hrmidi: file '{args.file}' not found.")
		sys.exit(1)
	language, hrmidi_format, output, stdout = args.l, args.f, args.o, args.stdout
	if not output: output = os.path.splitext(os.path.basename(args.file))[0]
	del parser, args

	source: dict = parse_hrmidi()
	del file
	if language == 'midi':
		output += ".mid"
		result: bytes = make_midi()
		if stdout:
			sys.stdout.buffer.write(result)
		else:
			with open(output, 'wb') as f: f.write(result) 
	else:
		output += f".{language}.hrmidi"
		result: str = make_hr()
		if stdout:
			print(result)
		else:
			with open(output, 'w') as f: f.write(result) 
